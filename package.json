{
  "name": "open-alice",
  "version": "0.9.0-beta.13",
  "description": "AI equity research assistant with focus-watchlist scoring",
  "type": "module",
  "scripts": {
    "dev": "pnpm dev:research",
    "dev:research": "tsx watch src/research-main.ts",
    "build": "pnpm build:research",
    "build:research": "turbo run build --filter=@traderalice/opentypebb && tsup src/research-main.ts --format esm --dts --out-dir dist/research",
    "start": "pnpm start:research",
    "start:research": "node dist/research/research-main.js",
    "test": "vitest run",
    "test:bbProvider": "vitest run --config vitest.bbProvider.config.ts",
    "test:watch": "vitest"
  },
  "keywords": [
    "equity-research",
    "ai-agent",
    "stock-analysis",
    "watchlist",
    "technical-analysis"
  ],
  "author": "OpenAlice Contributors",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TraderAlice/OpenAlice.git"
  },
  "homepage": "https://traderalice.com",
  "packageManager": "pnpm@10.29.2",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.44",
    "@ai-sdk/google": "^3.0.30",
    "@ai-sdk/openai": "^3.0.30",
    "@anthropic-ai/claude-agent-sdk": "^0.2.72",
    "@hono/node-server": "^2.0.0",
    "@traderalice/opentypebb": "workspace:*",
    "ai": "^6.0.86",
    "chalk": "^5.6.2",
    "hono": "^4.12.14",
    "json5": "^2.2.3",
    "openai": "^6.33.0",
    "pino": "^10.3.1",
    "tslog": "^4.10.2",
    "undici": "^7.24.4",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "overrides": {
      "lodash": "^4.18.0",
      "path-to-regexp": "^8.4.0",
      "follow-redirects": "^1.16.0",
      "express-rate-limit": "^8.2.2",
      "picomatch": "^4.0.4",
      "rollup": "^4.59.0",
      "vitest>vite": "^7.3.2",
      "@vitest/mocker>vite": "^7.3.2"
    }
  },
  "devDependencies": {
    "@ai-sdk/provider": "^3.0.8",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^29.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "turbo": "^2.9.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
